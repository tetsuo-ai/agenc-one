[Unit]
Description=Create AgenC data directories
After=agenc-data.mount
Requires=agenc-data.mount
ConditionPathIsMountPoint=/data

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/mkdir -p /data/agenc /data/keystore /data/agenc/logs /data/agenc/dropbear
ExecStart=/bin/chmod 700 /data/keystore /data/agenc/dropbear

[Install]
WantedBy=multi-user.target
